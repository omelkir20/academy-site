# ─── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=learning
POSTGRES_PASSWORD=learning_secret
POSTGRES_DB=learning_db

# ─── MongoDB ─────────────────────────────────────────────
MONGO_USER=learning
MONGO_PASSWORD=learning_secret

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ─── MinIO ───────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin_secret

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=supersecretjwtkey_change_in_production
JWT_EXPIRES_IN=7d

# ─── n8n ─────────────────────────────────────────────────
N8N_USER=admin@learning.local
N8N_PASSWORD=admin_secret

# ─── AI Tutor ────────────────────────────────────────────
# Provide your OpenAI API key or leave blank to use mock mode
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
